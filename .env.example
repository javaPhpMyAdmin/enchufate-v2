# --------------------------------------------------------------------------
# enchufate-v2 — environment variables
# --------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. The `.env` file is
# gitignored; never commit it.
#
# The V1 Supabase anon key was revoked. A fresh key is required before
# any auth or data code can run. See openspec/ONBOARDING.md for how to
# provision a new one.
# --------------------------------------------------------------------------

# Supabase project URL (e.g. https://qmoomdsaqywltaretbef.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key — safe to ship in the client bundle.
# RLS policies gate what each user can do. The service_role key MUST
# NEVER appear here.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

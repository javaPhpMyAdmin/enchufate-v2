{
  "expo": {
    "name": "Enchufate",
    "slug": "enchufate-v2",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "enchufate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enchufate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Enchufate usa tu ubicación para mostrar cargadores cercanos y centrar el mapa."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FF6B1F"
      },
      "package": "com.enchufate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

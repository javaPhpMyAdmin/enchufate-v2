{
  "expo": {
    "name": "Enchufate",
    "slug": "enchufate-v2",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "enchufate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enchufate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Enchufate usa tu ubicación para mostrar cargadores cercanos y centrar el mapa.",
        "NSPhotoLibraryUsageDescription": "Enchufate necesita acceso a tus fotos para que puedas mostrar tu cargador."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FF6B1F"
      },
      "package": "com.enchufate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@maplibre/maplibre-react-native",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89baec1c-7fdd-4972-a65b-5f5fd5f490e7"
      }
    },
    "owner": "chelobat.dev"
  }
}
